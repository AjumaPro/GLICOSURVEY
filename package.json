{
  "name": "survey-guy",
  "version": "1.0.0",
  "description": "A comprehensive survey platform with drag & drop builder, emoji scales, and real-time analytics",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "setup-db": "node server/database/setup.js",
    "migrate": "node server/database/migrate.js",
    "create-admin": "node server/scripts/create-super-admin.js",
    "create-test-admin": "node server/scripts/create-admin-user.js",
    "create-guest": "node server/scripts/create-guest-user.js",
    "create-platinum-template": "node server/scripts/create-platinum-banking-template.js",
    "start": "node server/index.js",
    "start:prod": "NODE_ENV=production node server/index.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "deploy": "npm run build && npm run pm2:restart",
    "setup-production": "npm run install-all && npm run build && npm run setup-db && npm run migrate && npm run create-admin",
    "iis:setup": "npm run install-all && npm run build && npm run setup-db && npm run migrate && npm run create-admin",
    "iis:deploy": "npm run build"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase": "^10.7.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "survey",
    "forms",
    "analytics",
    "emoji-scales",
    "drag-drop"
  ],
  "author": "SurveyGuy Team",
  "license": "MIT"
}
